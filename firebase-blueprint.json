{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the hosting platform",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address"
        },
        "name": {
          "type": "string",
          "description": "User's display name"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "User's role"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Plan": {
      "title": "Hosting Plan",
      "description": "A hosting plan available for purchase",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the plan"
        },
        "type": {
          "type": "string",
          "description": "Type of hosting (e.g., Minecraft, VPS)"
        },
        "price": {
          "type": "number",
          "description": "Monthly price"
        },
        "ram": {
          "type": "string",
          "description": "Amount of RAM"
        },
        "status": {
          "type": "string",
          "enum": ["Active", "Inactive"],
          "description": "Status of the plan"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        }
      },
      "required": ["name", "type", "price", "ram", "status", "createdAt"]
    },
    "Server": {
      "title": "Deployed Server",
      "description": "A server deployed by a user",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the server"
        },
        "type": {
          "type": "string",
          "description": "Type of the server"
        },
        "status": {
          "type": "string",
          "enum": ["Online", "Offline", "Starting", "Stopping"],
          "description": "Current status"
        },
        "ip": {
          "type": "string",
          "description": "IP address"
        },
        "userId": {
          "type": "string",
          "description": "ID of the user who owns the server"
        },
        "planId": {
          "type": "string",
          "description": "ID of the plan this server uses"
        },
        "specs": {
          "type": "object",
          "properties": {
            "ram": { "type": "string" },
            "cpu": { "type": "string" },
            "ssd": { "type": "string" }
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        }
      },
      "required": ["name", "type", "status", "userId", "planId", "createdAt"]
    },
    "Payment": {
      "title": "Payment",
      "description": "A payment submission for a plan",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "ID of the user who made the payment"
        },
        "planId": {
          "type": "string",
          "description": "ID of the plan purchased"
        },
        "planName": {
          "type": "string",
          "description": "Name of the plan purchased"
        },
        "amount": {
          "type": "string",
          "description": "Amount paid"
        },
        "upiId": {
          "type": "string",
          "description": "The user's UPI ID used for payment"
        },
        "utrId": {
          "type": "string",
          "description": "The transaction UTR ID"
        },
        "specs": {
          "type": "object",
          "properties": {
            "ram": { "type": "string" },
            "cpu": { "type": "string" },
            "ssd": { "type": "string" }
          }
        },
        "screenshotUrl": {
          "type": "string",
          "description": "URL of the payment screenshot"
        },
        "status": {
          "type": "string",
          "enum": ["Pending", "Approved", "Rejected"],
          "description": "Status of the payment"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        }
      },
      "required": ["userId", "planId", "amount", "screenshotUrl", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Collection of users"
    },
    "/plans/{planId}": {
      "schema": { "$ref": "#/entities/Plan" },
      "description": "Collection of hosting plans"
    },
    "/servers/{serverId}": {
      "schema": { "$ref": "#/entities/Server" },
      "description": "Collection of deployed servers"
    },
    "/payments/{paymentId}": {
      "schema": { "$ref": "#/entities/Payment" },
      "description": "Collection of payments"
    }
  }
}
